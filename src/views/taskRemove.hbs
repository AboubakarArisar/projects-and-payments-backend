<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Task Deleted</title>
    <link
      href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-100">
    <div
      class="max-w-2xl mx-auto mt-10 p-6 bg-white border border-gray-300 shadow-lg"
    >
      <div class="bg-green-500 text-white py-4 px-6 rounded-t-lg">
        <h2 class="text-2xl">Notification: Task Deleted </h2>
      </div>
      <div class="p-6">
        <p class="text-lg">Hello {{userName}},</p>
        <p>{{taskDescription}}</p>
      </div>
      <div class="bg-gray-100 py-4 px-6 rounded-b-lg">
        <p>Best Regards,</p>
        <p>ProjectProTrack</p>
      </div>
    </div>
  </body>
</html>
