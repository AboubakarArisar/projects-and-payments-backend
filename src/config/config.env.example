# ------------------------------------------------------------------
# Backend environment config
# The app loads this file from: src/config/config.env  (see src/server.js)
# Copy this file to  src/config/config.env  and fill in real values:
#   cp src/config/config.env.example src/config/config.env
# ------------------------------------------------------------------

# Server
PORT=5000
NODE_ENV=DEVELOPMENT

# MongoDB
# Base connection string ONLY. The app appends "/projects-payments-db" itself.
# Local Mongo example:
DB_LOCAL_URI=mongodb://127.0.0.1:27017
# MongoDB Atlas example (no trailing db name / slash):
# DB_LOCAL_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# JWT (used to sign auth tokens)
JWT_SECRET=change_me_to_a_long_random_string

# Email (Gmail SMTP via nodemailer "gmail" service)
# SMTP_PASSWORD must be a Gmail *App Password*, not your normal password.
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=Projects And Payments
SMTP_FROM_EMAIL=your_gmail_address@gmail.com

# Google Gemini (AI Assistant features) — get a free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
